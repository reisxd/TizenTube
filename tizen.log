/*# sourceMappingURL=account_switch_reload_splash_style.css.map */</style><style nonce="">body, html {height: 100%; font-size: 100%; margin: auto; overflow: hidden; padding: 0;}.focused, :focus {outline: 0;}.hidden {display: none !important;}body, html {-moz-user-select: none; -webkit-user-select: none; user-select: none;}body {background-color: #1c1a1a; font-size: 1rem;}#loader {height: 100%; left: 0; position: absolute; top: 0; width: 100%; z-index: 0; background-position: center center; background-repeat: no-repeat; background-color: #282828;}</style><script nonce="">var setMessage=function(msg){if(window.yt&&yt.setMsg)yt.setMsg(msg);else{window.ytcfg=window.ytcfg||{};ytcfg.msgs=msg}};
setMessage({"A11Y_CAPITAL_LETTER":"Großes ${letter}","A11Y_CHANGE_LANGUAGE_BUTTON":"Sprache ändern","A11Y_HIDDEN_KEYBOARD_KEY":"Ausgewählt","A11Y_KEYBOARD":"Tastatur","A11Y_LESS_THAN_ONE_MIN_LEFT":"Noch weniger als 1 Minute","A11Y_NUMBERS_AND_SYMBOLS_BUTTON":"Nummern und Symbole","A11Y_REGULAR_KEYBOARD_BUTTON":"Buchstaben","A11Y_SQUEEZEBACK_PLAYER":"Vollbild","A11Y_SUGGESTIONS_RECENT":"Letzte Suchanfragen","A11Y_SUGGESTIONS_RECOMMENDED":"Empfohlene Suchanfragen","A11Y_SUGGESTIONS_REGULAR":"Vorgeschlagene Suchanfragen","A11Y_SUGGESTIONS_TRENDING":"Trends bei Suchanfragen","A11Y_SUGGESTION_POSITION":"${index} von ${total}","ABOUT_SEARCH_RESULTS_SIDEPANEL_CONTENT":"In der YouTube-Suche spielen für bestmögliche Suchergebnisse vor allem drei Faktoren eine wichtige Rolle: Relevanz, Interaktionen und Qualität. Je nach Art der Suche werden diese drei Faktoren unterschiedlich gewichtet. Zur Beurteilung der Relevanz sehen wir uns unter anderem an, inwiefern Titel, Tags, Beschreibung und Videoinhalte der Suchanfrage entsprechen. Auch die Interaktionen zu einem Video geben uns Anhaltspunkte zur Relevanz. Dafür betrachten wir eine Reihe von Signalen, die die Interaktion der Nutzer abbilden, wie z. B. die Wiedergabezeit eines bestimmten Videos zu einer bestimmten Suchanfrage. So können wir ermitteln, ob das Video auch für dieselben Suchanfragen anderer Nutzer relevant sein könnte. Außerdem haben wir unsere Systeme so entwickelt, dass sie Signale erkennen, die auf die Verlässlichkeit und Kompetenz eines Kanals in Bezug auf ein bestimmtes Thema hindeuten. YouTube akzeptiert keine Zahlungen für eine bessere Platzierung in den organischen Suchergebnissen.","ABOUT_SEARCH_RESULTS_SIDEPANEL_HEADER":"Die YouTube-Suche","ABOUT_SEARCH_RESULTS_TITLE":"Informationen zu diesen Ergebnissen","ACCOUNTS_SURFACE_TITLE_MULTIPLE_ACCOUNTS":"Konten","ACCOUNTS_SURFACE_TITLE_ONE_ACCOUNT":"Konto","ACCOUNT_BYLINE_WITH_SIGNED_OUT_TEXT":"${accountByline} • Abgemeldet","ACCOUNT_LOCK_CONFIRM_SUBTITLE":"Code z